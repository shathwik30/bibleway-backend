# =============================================================================
# Bibleway Backend — Environment Variables
# =============================================================================
# Copy this file to .env and fill in real values.
# Variables with a default value in parentheses are optional.
# =============================================================================

# -- Django Core --------------------------------------------------------------

# Environment: "dev", "prod", or "test"
DJANGO_ENV=dev

# Secret key for cryptographic signing (generate a strong random string)
DJANGO_SECRET_KEY=your-secret-key-here

# Comma-separated list of allowed hostnames (default: localhost,127.0.0.1)
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated list of allowed CORS origins (production only)
# In dev, all origins are allowed. In prod, restrict to your app's domains.
CORS_ALLOWED_ORIGINS=https://bibleway.io

# -- Database (Railway PostgreSQL) --------------------------------------------

DATABASE_URL=postgresql://user:password@host:port/railway

# -- Redis --------------------------------------------------------------------
# Used for: cache, Celery broker, Django Channels, session storage
# Leave empty to use in-memory fallbacks for local development

UPSTASH_REDIS_URL=redis://default:password@host:port

# -- Railway Object Storage (S3-compatible) -----------------------------------
# Used for: profile photos, post/prayer media, product files, covers
# Leave AWS_ACCESS_KEY_ID empty to fall back to local FileSystemStorage

AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_STORAGE_BUCKET_NAME=your_bucket_name
AWS_S3_ENDPOINT_URL=https://t3.storageapi.dev
AWS_S3_REGION_NAME=auto

# -- Firebase Admin SDK -------------------------------------------------------
# Service-account JSON for verifying Firebase ID tokens (Google Sign-In).
# Get from: Firebase Console > Project Settings > Service Accounts > Generate New Key
# Paste the entire JSON as a single-line string.

FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# -- Resend (Email) -----------------------------------------------------------
# Used for: OTP verification emails, password reset emails

RESEND_API_KEY=re_xxxxxxxxxxxx

# -- API Bible ----------------------------------------------------------------
# Server-side key for the api.bible REST API proxy
# Used by: apps/bible/views.py (ApiBibleProxyView)

API_BIBLE_KEY=your_api_bible_key

# -- Google Cloud Translation -------------------------------------------------
# Used for: translating segregated Bible page content on cache miss

GOOGLE_TRANSLATE_API_KEY=your_google_translate_api_key

# -- Apple In-App Purchase Verification ---------------------------------------
# Used by: apps/shop/validators.py (validate_apple_receipt)

APPLE_SHARED_SECRET=your_apple_shared_secret
APPLE_BUNDLE_ID=com.bibleway.io

# -- Google Play In-App Purchase Verification ---------------------------------
# Used by: apps/shop/validators.py (validate_google_receipt)
# JSON string of the Google Play service account credentials

GOOGLE_PLAY_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
ANDROID_PACKAGE_NAME=com.bibleway.io
