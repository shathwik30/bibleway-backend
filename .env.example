# Django
DJANGO_ENV=dev
DJANGO_SECRET_KEY=your_secret_key_here
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Neon PostgreSQL
DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.us-east-1.aws.neon.tech/bibleway?sslmode=require
DATABASE_DIRECT_URL=postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/bibleway?sslmode=require

# UploadThing
UPLOADTHING_TOKEN=your_uploadthing_api_key
UPLOADTHING_APP_ID=your_uploadthing_app_id

# Upstash Redis
UPSTASH_REDIS_URL=rediss://default:<password>@<endpoint>.upstash.io:6379

# Firebase
FIREBASE_CREDENTIALS_JSON={"type":"service_account",...}

# Resend (Email)
RESEND_API_KEY=re_xxxxxxxxxxxx

# Google Translate
GOOGLE_TRANSLATE_API_KEY=your_google_api_key

# API Bible
API_BIBLE_KEY=your_api_bible_key

# Apple IAP
APPLE_SHARED_SECRET=your_apple_shared_secret
APPLE_BUNDLE_ID=com.bibleway.app

# Google Play
GOOGLE_PLAY_CREDENTIALS_JSON={"type":"service_account",...}
ANDROID_PACKAGE_NAME=com.bibleway.app

# Sentry
SENTRY_DSN=https://xxxx@o0.ingest.sentry.io/xxxx

# CORS (prod only)
CORS_ALLOWED_ORIGINS=https://admin.bibleway.app,https://bibleway.app
